        "from transformers import AutoTokenizer, Trainer, TrainingArguments, AutoModelForSequenceClassification, EarlyStoppingCallback\n",
        "import pandas as pd\n",
        "\n",
        "# Load the Model and Tokenizer\n",
        "output_dir = './Model'\n",
        "tokenizer = AutoTokenizer.from_pretrained(output_dir)\n",
        "model = AutoModelForSequenceClassification.from_pretrained(output_dir)\n",
        "\n",
        "# Initialize a basic Trainer just for prediction\n",
        "trainer = Trainer(model=model)\n",
        "\n",
        "# Load the Dev and Test Sets\n",
        "# First, load the main dataset to get access to the text columns\n",
        "main_column_names = ['par_id', 'art_id', 'keyword', 'country', 'text', 'label']\n",
        "main_df = pd.read_csv('dontpatronizeme_pcl.tsv', sep='\\t', skiprows=4, names=main_column_names)\n",
        "main_df['par_id'] = main_df['par_id'].astype(str)\n",
        "\n",
        "# Load the dev IDs and join them to get the text\n",
        "dev_ids = pd.read_csv('dev_semeval_parids-labels.csv')\n",
        "dev_ids['par_id'] = dev_ids['par_id'].astype(str)\n",
        "\n",
        "dev_df = pd.merge(dev_ids, main_df, on='par_id', how='left')\n",
        "dev_df['text'] = dev_df['text'].fillna(\" \")\n",
        "\n",
        "# Load the official test set\n",
        "test_df = pd.read_csv('task4_test.tsv', sep='\\t', names=['par_id', 'art_id', 'keyword', 'country', 'text'])\n",
        "test_df = test_df.dropna(subset=['text'])\n",
        "\n",
        "# 3. Tokenize the Data\n",
        "def tokenize_texts(texts):\n",
        "    return tokenizer(\n",
        "        texts.tolist(),\n",
        "        padding=\"max_length\",\n",
        "        truncation=True,\n",
        "        max_length=128,\n",
        "        return_tensors=\"pt\"\n",
        "    )\n",
        "\n",
        "dev_encodings = tokenize_texts(dev_df['text'])\n",
        "test_encodings = tokenize_texts(test_df['text'])\n",
        "\n",
        "class SimpleDataset(torch.utils.data.Dataset):\n",
        "    def __init__(self, encodings):\n",
        "        self.encodings = encodings\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        return {key: torch.tensor(val[idx]) for key, val in self.encodings.items()}\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.encodings.input_ids)\n",
        "\n",
        "dev_dataset = SimpleDataset(dev_encodings)\n",
        "test_dataset = SimpleDataset(test_encodings)\n",
        "\n",
        "# 4. Generate Predictions\n",
        "print(\"Predicting on Dev Set...\")\n",
        "dev_predictions = trainer.predict(dev_dataset)\n",
        "dev_preds = np.argmax(dev_predictions.predictions, axis=-1)\n",
        "\n",
        "print(\"Predicting on Test Set...\")\n",
        "test_predictions = trainer.predict(test_dataset)\n",
        "test_preds = np.argmax(test_predictions.predictions, axis=-1)\n",
        "\n",
        "# 5. Save to .txt files (One prediction per line)\n",
        "with open(\"dev.txt\", \"w\") as f:\n",
        "    for pred in dev_preds:\n",
        "        f.write(f\"{pred}\\n\")\n",
        "\n",
        "with open(\"test.txt\", \"w\") as f:\n",
        "    for pred in test_preds:\n",
        "        f.write(f\"{pred}\\n\")\n",
        "\n",
        "print(\"Successfully generated dev.txt and test.txt\")\n"
      ]
    },
