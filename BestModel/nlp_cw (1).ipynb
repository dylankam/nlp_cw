      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# 1. Load and clean the dataset\n",
        "file_path = 'dontpatronizeme_pcl.tsv'\n",
        "column_names = ['par_id', 'art_id', 'keyword', 'country', 'text', 'label']\n",
        "\n",
        "df = pd.read_csv(file_path, sep='\\t', skiprows=4, names=column_names)\n",
        "df = df.dropna(subset=['text', 'label'])\n",
        "df['label'] = pd.to_numeric(df['label'], errors='coerce')\n",
        "df = df.dropna(subset=['label'])\n",
        "\n",
        "# 2. Map original 0-4 labels to Binary Classification (0 or 1)\n",
        "df['binary_label'] = df['label'].apply(lambda x: 0 if x in [0, 1] else 1)"
      ]
    },
