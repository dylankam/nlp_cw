      "source": [
        "import numpy as np\n",
        "import torch\n",
        "from sklearn.utils.class_weight import compute_class_weight\n",
        "from sklearn.metrics import f1_score, accuracy_score, precision_score, recall_score\n",
        "\n",
        "# Load the main dataset\n",
        "file_path = 'dontpatronizeme_pcl.tsv'\n",
        "column_names = ['par_id', 'art_id', 'keyword', 'country', 'text', 'label']\n",
        "df = pd.read_csv(file_path, sep='\\t', skiprows=4, names=column_names)\n",
        "df = df.dropna(subset=['text', 'label'])\n",
        "df['label'] = pd.to_numeric(df['label'], errors='coerce')\n",
        "df = df.dropna(subset=['label'])\n",
        "\n",
        "# Map to binary classification (0,1 -> 0; 2,3,4 -> 1)\n",
        "df['binary_label'] = df['label'].apply(lambda x: 0 if x in [0, 1] else 1)\n",
        "\n",
        "# Ensure par_id is a string for merging\n",
        "df['par_id'] = df['par_id'].astype(str)\n",
        "\n",
        "# Load the official train/dev splits\n",
        "trids = pd.read_csv('train_semeval_parids-labels.csv')\n",
        "teids = pd.read_csv('dev_semeval_parids-labels.csv')\n",
        "trids['par_id'] = trids['par_id'].astype(str)\n",
        "teids['par_id'] = teids['par_id'].astype(str)\n",
        "\n",
        "# Merge to create official train and dev dfs\n",
        "train_df = df[df['par_id'].isin(trids['par_id'])].copy()\n",
        "dev_df = df[df['par_id'].isin(teids['par_id'])].copy()\n",
        "\n",
        "print(f\"Training set size: {len(train_df)}\")\n",
        "print(f\"Dev set size: {len(dev_df)}\")\n",
        "\n",
        "# Calculate Class Weights for the Training Set\n",
        "class_weights = compute_class_weight(\n",
        "    class_weight='balanced',\n",
        "    classes=np.unique(train_df['binary_label']),\n",
        "    y=train_df['binary_label']\n",
        ")\n",
        "# Convert to PyTorch tensor to pass into our loss function later\n",
        "class_weights_tensor = torch.tensor(class_weights, dtype=torch.float)\n",
        "print(f\"Calculated Class Weights: {class_weights_tensor}\")"
      ]
    },
